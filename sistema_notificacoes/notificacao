package notifcacoes;

public class notifcacao {

    private String destinatario;

    public notifcacao(String destinatario) {
        Validacao.validarDestinatario(destinatario);
        this.destinatario = destinatario;
    }

    public String getDestinatario() {
        return destinatario;
    }

    public void setDestinatario(String destinatario) {
        Validacao.validarDestinatario(destinatario);
        this.destinatario = destinatario;
    }

    public void enviar(String mensagem) {
        Validacao.validarMensagem(mensagem);
        System.out.println("Enviando notificação para " + this.destinatario + " - Mensagem: " + mensagem);
    }
}
